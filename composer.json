{
    "name": "twisted1919/zerobounce",
    "version": "2.0.0",
    "description": "ZeroBounce Email Verification Library for PHP",
    "homepage": "https://www.zerobounce.net",
    "autoload": {
        "psr-0": {
            "ZeroBounce\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-0": {
            "ZeroBounce\\Test\\": "test/"
        }
    },
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "ext-curl": "*",
        "guzzlehttp/guzzle": "^7.10.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5.43",
        "friendsofphp/php-cs-fixer": "^3.89.1",
        "phpstan/phpstan": "^2.1.31",
        "rector/rector": "^2.2"
    },
    "scripts": {
        "test": "./vendor/bin/phpunit",
        "php-cs-fixer": "./vendor/bin/php-cs-fixer fix .",
        "phpstan": "./vendor/bin/phpstan analyse src test example -c phpstan.neon --level max --memory-limit=-1",
        "rector": "./vendor/bin/rector src test example"
    },
    "license": "MIT"
}
